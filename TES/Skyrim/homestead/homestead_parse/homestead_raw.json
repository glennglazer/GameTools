    {
      "index": "25",
      "number": "5.5.2",
      "title": "Room with Outdoor Patio",
      "html": "<div class=\"mw-content-ltr mw-parser-output\" lang=\"en\" dir=\"ltr\"><h4><span class=\"mw-headline\" id=\"Room_with_Outdoor_Patio\">Room with Outdoor Patio</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><span class=\"mw-editsection-bracket\">]</span></span></h4>\n<p>The construction recipe for the Bedrooms, Storage Room or Armory is:\n</p>\n<table class=\"wikitable sortable\" width=\"100%\" style=\"text-align: center;\">\n<tbody><tr>\n<th>Stage\n</th>\n<th>Section\n</th>\n<th>Sawn Logs\n</th>\n<th>Quarried Stone\n</th>\n<th>Nails\n</th>\n<th>Clay\n</th>\n<th>Iron Fittings\n</th>\n<th>Lock\n</th>\n<th>Hinge\n</th></tr>\n<tr>\n<th>Stage 1\n</th>\n<td>Doors\n</td>\n<td>3\n</td>\n<td>-\n</td>\n<td>6\n</td>\n<td>-\n</td>\n<td>3\n</td>\n<td>3\n</td>\n<td>6\n</td></tr>\n<tr>\n<th>Stage 2\n</th>\n<td>Foundation\n</td>\n<td>2\n</td>\n<td>10\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td></tr>\n<tr>\n<th>Stage 3\n</th>\n<td>Floor\n</td>\n<td>-\n</td>\n<td>4\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td></tr>\n<tr>\n<th>\n</th>\n<td>Wall Supports\n</td>\n<td>7\n</td>\n<td>-\n</td>\n<td>8\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td></tr>\n<tr>\n<th>Stage 4\n</th>\n<td>Roof\n</td>\n<td>1\n</td>\n<td>4\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td></tr>\n<tr>\n<th>Stage 5\n</th>\n<td>Walls\n</td>\n<td>1\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>3\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td></tr>\n<tr>\n<th>Total\n</th>\n<td>-\n</td>\n<td>14\n</td>\n<td>18\n</td>\n<td>14\n</td>\n<td>3\n</td>\n<td>3\n</td>\n<td>3\n</td>\n<td>6\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260717014305\nCache expiry: 1209600\nReduced expiry: false\nComplications: []\nCPU time usage: 0.005 seconds\nReal time usage: 0.005 seconds\nPreprocessor visited node count: 2/1000000\nPost‐expand include size: 0/2097152 bytes\n