      "index": "24",
      "number": "5.5.1",
      "title": "Tower",
      "html": "<div class=\"mw-content-ltr mw-parser-output\" lang=\"en\" dir=\"ltr\"><h4><span class=\"mw-headline\" id=\"Tower\">Tower</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><span class=\"mw-editsection-bracket\">]</span></span></h4>\n<p>The construction recipe for the Enchanter's Tower, Alchemy Laboratory or Library is:\n</p>\n<table class=\"wikitable sortable\" width=\"100%\" style=\"text-align: center;\">\n<tbody><tr>\n<th>Stage\n</th>\n<th>Section\n</th>\n<th>Sawn Log\n</th>\n<th>Quarried Stone\n</th>\n<th>Nails\n</th>\n<th>Clay\n</th>\n<th>Iron Fittings\n</th>\n<th>Lock\n</th>\n<th>Hinge\n</th></tr>\n<tr>\n<th>Stage 1\n</th>\n<td>Doors\n</td>\n<td>3\n</td>\n<td>-\n</td>\n<td>6\n</td>\n<td>-\n</td>\n<td>3\n</td>\n<td>3\n</td>\n<td>6\n</td></tr>\n<tr>\n<th>Stage 2\n</th>\n<td>Foundation\n</td>\n<td>2\n</td>\n<td>8\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td></tr>\n<tr>\n<th>Stage 3\n</th>\n<td>Floor\n</td>\n<td>-\n</td>\n<td>4\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td></tr>\n<tr>\n<th>\n</th>\n<td>Main Supports\n</td>\n<td>10\n</td>\n<td>-\n</td>\n<td>10\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td></tr>\n<tr>\n<th>Stage 4\n</th>\n<td>1st Floor Walls\n</td>\n<td>1\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>3\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td></tr>\n<tr>\n<th>\n</th>\n<td>2nd Floor Supports\n</td>\n<td>4\n</td>\n<td>-\n</td>\n<td>12\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td></tr>\n<tr>\n<th>Stage 5\n</th>\n<td>2nd Level Walls\n</td>\n<td>2\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>6\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td></tr>\n<tr>\n<th>Stage 6\n</th>\n<td>Roof\n</td>\n<td>1\n</td>\n<td>4\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</td></tr>\n<tr>\n<th>Stage 7\n</th>\n<td>Roof Canopy\n</td>\n<td>1\n</td>\n<td>-\n</td>\n<td>6\n</td>\n<td>-\n</td>\n<td>-\n</td>\n<td>-\n</t