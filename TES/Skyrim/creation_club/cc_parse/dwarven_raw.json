\n</th>\n<th><a href=\"/wiki/File:SR-item-Gold-heads.png\" class=\"image\" title=\"Value\"><img alt=\"Value\" src=\"//images.uesp.net/thumb/5/52/SR-item-Gold-heads.png/22px-SR-item-Gold-heads.png\" width=\"22\" height=\"22\" srcset=\"//images.uesp.net/thumb/5/52/SR-item-Gold-heads.png/33px-SR-item-Gold-heads.png 1.5x, //images.uesp.net/thumb/5/52/SR-item-Gold-heads.png/44px-SR-item-Gold-heads.png 2x\" /></a>\n</th></tr>\n<tr>\n<td><a href=\"/wiki/File:SR-icon-armor-Dwarven_Plate_Armor.png\" class=\"image\"><img alt=\"SR-icon-armor-Dwarven Plate Armor.png\" src=\"//images.uesp.net/thumb/f/f5/SR-icon-armor-Dwarven_Plate_Armor.png/48px-SR-icon-armor-Dwarven_Plate_Armor.png\" width=\"48\" height=\"48\" srcset=\"//images.uesp.net/thumb/f/f5/SR-icon-armor-Dwarven_Plate_Armor.png/72px-SR-icon-armor-Dwarven_Plate_Armor.png 1.5x, //images.uesp.net/thumb/f/f5/SR-icon-armor-Dwarven_Plate_Armor.png/96px-SR-icon-armor-Dwarven_Plate_Armor.png 2x\" /></a>\n</td>\n<td><span id=\"Dwarven_Plate_Armor\"></span>Dwarven Plate Armor<br /><span class=\"idall\">(<span class=\"idref\"><span class=\"idcase\">FE</span><a href=\"/wiki/Skyrim:Form_ID#Creation_Club\" title=\"Skyrim:Form ID\"><span style=\"cursor:help;\" title=\"These three digits vary depending on installed Creations. Click for more details.\">xxx</span></a><span class=\"idcase\">801</span></span>)</span></td>\n<td>45</td>\n<td>500</td>\n<td>35\n</td>\n<td style=\"border-left-width:medium; border-left-color:black;\">3</td>\n<td>1</td>\n<td>1</td>\n<td>3\n</td>\n<td style=\"border-left-width:medium; border-left-color:black; color:red\">39.7\n</td>\n<td>374\n</td>\n<td style=\"color:red\">8.49\n</td>\n<td>3.97\n</td></tr>\n<tr>\n<td><a href=\"/wiki/File:SR-icon-armor-Dwarven_Plate_Boots.png\" class=\"image\"><img alt=\"SR-icon-armor-Dwarven Plate Boots.png\" src=\"//images.uesp.net/thumb/c/ce/SR-icon-armor-Dwarven_Plate_Boots.png/48px-SR-icon-armor-Dwarven_Plate_Boots.png\" width=\"48\" height=\"48\" srcset=\"//images.uesp.net/thu