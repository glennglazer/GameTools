td>\n<td>3\n</td>\n<td style=\"border-left-width:medium; border-left-color:black; color:red\">32.7\n</td>\n<td>529\n</td>\n<td style=\"color:red\">7.17\n</td>\n<td>6.51\n</td></tr>\n<tr>\n<td><a href=\"/wiki/File:SR-icon-armor-Vigil_Corrupted_Sashed_Armor.png\" class=\"image\"><img alt=\"SR-icon-armor-Vigil Corrupted Sashed Armor.png\" src=\"//images.uesp.net/thumb/c/cd/SR-icon-armor-Vigil_Corrupted_Sashed_Armor.png/48px-SR-icon-armor-Vigil_Corrupted_Sashed_Armor.png\" width=\"48\" height=\"48\" srcset=\"//images.uesp.net/thumb/c/cd/SR-icon-armor-Vigil_Corrupted_Sashed_Armor.png/72px-SR-icon-armor-Vigil_Corrupted_Sashed_Armor.png 1.5x, //images.uesp.net/thumb/c/cd/SR-icon-armor-Vigil_Corrupted_Sashed_Armor.png/96px-SR-icon-armor-Vigil_Corrupted_Sashed_Armor.png 2x\" /></a><a href=\"/wiki/File:SR-icon-armor-Vigil_Veteran_Sashed_Armor.png\" class=\"image\"><img alt=\"SR-icon-armor-Vigil Veteran Sashed Armor.png\" src=\"//images.uesp.net/thumb/e/ef/SR-icon-armor-Vigil_Veteran_Sashed_Armor.png/48px-SR-icon-armor-Vigil_Veteran_Sashed_Armor.png\" width=\"48\" height=\"48\" srcset=\"//images.uesp.net/thumb/e/ef/SR-icon-armor-Vigil_Veteran_Sashed_Armor.png/72px-SR-icon-armor-Vigil_Veteran_Sashed_Armor.png 1.5x, //images.uesp.net/thumb/e/ef/SR-icon-armor-Vigil_Veteran_Sashed_Armor.png/96px-SR-icon-armor-Vigil_Veteran_Sashed_Armor.png 2x\" /></a>\n</td>\n<td><span id=\"Vigil_Corrupted_Sashed_Armor\"></span>Vigil Corrupted Sashed Armor<br /><span class=\"idall\">(<span class=\"idref\"><span class=\"idcase\">FE</span><a href=\"/wiki/Skyrim:Form_ID#Creation_Club\" title=\"Skyrim:Form ID\"><span style=\"cursor:help;\" title=\"These three digits vary depending on installed Creations. Click for more details.\">xxx</span></a><span class=\"idcase\">803</span></span>)</span><br /><span id=\"Vigil_Veteran_Sashed_Armor\"></span>Vigil Veteran Sashed Armor<br /><span class=\"idall\">(<span class=\"idref\"><span class=\"idcase\">FE</span><a href=\"/wiki/Skyrim:Form_ID#Creation_Club\" title