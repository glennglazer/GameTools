    "4": {
      "title": "Ingredients",
      "html": "<div class=\"mw-parser-output\"><h2><span class=\"mw-headline\" id=\"Ingredients\">Ingredients</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/w/index.php?title=Skyrim:Bittercup_Items&amp;action=edit&amp;section=1\" title=\"Edit section: Ingredients\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<table class=\"wikitable\">\n<tbody><tr>\n<th colspan=\"2\">Ingredient Name (<a href=\"/wiki/Skyrim:Form_ID\" title=\"Skyrim:Form ID\">ID</a>)\n</th>\n<th>Primary Effect\n</th>\n<th>Secondary Effect\n</th>\n<th>Tertiary Effect\n</th>\n<th>Quaternary Effect\n</th>\n<th width=\"22\"><a href=\"/wiki/File:SR-item-Gold-heads.png\" class=\"image\" title=\"Value\"><img alt=\"Value\" src=\"//images.uesp.net/thumb/5/52/SR-item-Gold-heads.png/22px-SR-item-Gold-heads.png\" width=\"22\" height=\"22\" srcset=\"//images.uesp.net/thumb/5/52/SR-item-Gold-heads.png/33px-SR-item-Gold-heads.png 1.5x, //images.uesp.net/thumb/5/52/SR-item-Gold-heads.png/44px-SR-item-Gold-heads.png 2x\" /></a>\n</th>\n<th width=\"22\"><a href=\"/wiki/File:SR-icon-clothing-Leather_Backpack_(square).png\" class=\"image\" title=\"Weight\"><img alt=\"Weight\" src=\"//images.uesp.net/thumb/2/2d/SR-icon-clothing-Leather_Backpack_%28square%29.png/22px-SR-icon-clothing-Leather_Backpack_%28square%29.png\" width=\"22\" height=\"22\" srcset=\"//images.uesp.net/thumb/2/2d/SR-icon-clothing-Leather_Backpack_%28square%29.png/33px-SR-icon-clothing-Leather_Backpack_%28square%29.png 1.5x, //images.uesp.net/thumb/2/2d/SR-icon-clothing-Leather_Backpack_%28square%29.png/44px-SR-icon-clothing-Leather_Backpack_%28square%29.png 2x\" /></a>\n</th></tr>\n\n\n<tr id=\"Healing_Salts\">\n<td rowspan=\"2\" style=\"width:1px; padding:1px\"><a href=\"/wiki/File:SR-icon-ingredient-Salt_Pile.png\" class=\"image\"><img alt=\"SR-icon-ingredient-Salt Pile.png\" src=\"//images.uesp.net/thumb/3/36/SR-icon-ingredient-Salt_Pile.png/48px-SR-icon-ingredient-Salt_Pile.png\" width=\"48\" height=\"48\" srcset=\"//images.uesp.net/thumb/3/36/SR-icon-ingredient-Salt_Pile.png/72px-SR-icon-ingredient-Salt_Pile.png 1.5x, //images.uesp.net/thumb/3/36/SR-icon-ingredient-Salt_Pile.png/96px-SR-icon-ingredient-Salt_Pile.png 2x\" /></a>\n</td>\n<td rowspan=\"2\"><a href=\"/wiki/Skyrim:Healing_Salts\" title=\"Skyrim:Healing Salts\">Healing Salts</a><br /><span class=\"idall\"><span class=\"idref\"><span class=\"idcase\">FE</span><a href=\"/wiki/Skyrim:Form_ID#Creation_Club\" title=\"Skyrim:Form ID\"><span style=\"cursor:help;\" title=\"These three digits vary depending on installed Creations. Click for more details.\">xxx</span></a><span class=\"idcase\">F86</span></span></span>\n</td>\n<td colspan=\"6\">Unused, unreferenced, and unobtainable duplicate of a <a href=\"/wiki/Skyrim:Salt_Pile\" title=\"Skyrim:Salt Pile\">Salt Pile</a>. Presumably replaced by the Ironwood Fruit.\n</td></tr>\n<tr>\n<td class=\"EffectNeg\"><a href=\"/wiki/Skyrim:Weakness_to_Magic\" title=\"Weakness to Magic\"><img alt=\"Weakness to Magic\" src=\"//images.uesp.net/thumb/a/ab/SR-icon-spell-Magic_Hat.png/16px-SR-icon-spell-Magic_Hat.png\" width=\"16\" height=\"16\" srcset=\"//images.uesp.net/thumb/a/ab/SR-icon-spell-Magic_Hat.png/24px-SR-icon-spell-Magic_Hat.png 1.5x, //images.uesp.net/thumb/a/ab/SR-icon-spell-Magic_Hat.png/32px-SR-icon-spell-Magic_Hat.png 2x\" /></a>&#160;<a href=\"/wiki/Skyrim:Weakness_to_Magic\" title=\"Skyrim:Weakness to Magic\">Weakness to Magic</a>\n</td>\n<td class=\"EffectPos\"><a href=\"/wiki/Skyrim:Fortify_Restoration\" title=\"Fortify Restoration\"><img alt=\"Fortify Restoration\" src=\"//images.uesp.net/thumb/a/ab/SR-icon-spell-Magic_Hat.png/16px-SR-icon-spell-Magic_Hat.png\" width=\"16\" height=\"16\" srcset=\"//images.uesp.net/thumb/a/ab/SR-icon-spell-Magic_Hat.png/24px-SR-icon-spell-Magic_Hat.png 1.5x, //images.uesp.net/thumb/a/ab/SR-icon-spell-Magic_Hat.png/32px-SR-icon-spell-Magic_Hat.png 2x\" /></a>&#160;<a href=\"/wiki/Skyrim:Fortify_Restoration\" title=\"Skyrim:Fortify Restoration\">Fortify Restoration</a>\n</td>\n<td class=\"EffectNeg\"><a href=\"/wiki/Skyrim:Slow\" title=\"Slow\"><img alt=\"Slow\" src=\"//images.uesp.net/thumb/0/06/SR-icon-spell-Ice.png/16px-SR-icon-spell-Ice.png\" width=\"16\" height=\"16\" srcset=\"//images.uesp.net/thumb/0/06/SR-icon-spell-Ice.png/24px-SR-icon-spell-Ice.png 1.5x, //images.uesp.net/thumb/0/06/SR-icon-spell-Ice.png/32px-SR-icon-spell-Ice.png 2x\" /></a>&#160;<a href=\"/wiki/Skyrim:Slow\" title=\"Skyrim:Slow\">Slow</a>\n</td>\n<td class=\"EffectPos\"><a href=\"/wiki/Skyrim:Regenerate_Magicka\" title=\"Regenerate Magicka\"><img alt=\"Regenerate Magicka\" src=\"//images.uesp.net/thumb/a/ab/SR-icon-spell-Magic_Hat.png/16px-SR-icon-spell-Magic_Hat.png\" width=\"16\" height=\"16\" srcset=\"//images.uesp.net/thumb/a/ab/SR-icon-spell-Magic_Hat.png/24px-SR-icon-spell-Magic_Hat.png 1.5x, //images.uesp.net/thumb/a/ab/SR-icon-spell-Magic_Hat.png/32px-SR-icon-spell-Magic_Hat.png 2x\" /></a>&#160;<a href=\"/wiki/Skyrim:Regenerate_Magicka\" title=\"Skyrim:Regenerate Magicka\">Regenerate Magicka</a>\n</td>\n<td>2\n</td>\n<td>0.2\n</td></tr>\n<tr id=\"Ironwood_Fruit\">\n<td rowspan=\"2\" style=\"width:1px; padding:1px\"><a href=\"/wiki/File:SR-icon-ingredient-Ironwood_Fruit.png\" class=\"image\"><img alt=\"SR-icon-ingredient-Ironwood Fruit.png\" src=\"//images.uesp.net/thumb/a/ab/SR-icon-ingredient-Ironwood_Fruit.png/48px-SR-icon-ingredient-Ironwood_Fruit.png\" width=\"48\" height=\"48\" srcset=\"//images.uesp.net/thumb/a/ab/SR-icon-ingredient-Ironwood_Fruit.png/72px-SR-icon-ingredient-Ironwood_Fruit.png 1.5x, //images.uesp.net/thumb/a/ab/SR-icon-ingredient-Ironwood_Fruit.png/96px-SR-icon-ingredient-Ironwood_Fruit.png 2x\" /></a>\n</td>\n<td rowspan=\"2\"><a href=\"/wiki/Skyrim:Ironwood_Fruit\" title=\"Skyrim:Ironwood Fruit\">Ironwood Fruit</a><br /><span class=\"idall\"><span class=\"idref\"><span class=\"idcase\">FE</span><a href=\"/wiki/Skyrim:Form_ID#Creation_Club\" title=\