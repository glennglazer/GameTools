ckpack_%28square%29.png/44px-SR-icon-clothing-Leather_Backpack_%28square%29.png 2x\" /></a>\n</th>\n<th><a href=\"/wiki/File:SR-item-Gold-heads.png\" class=\"image\" title=\"Value\"><img alt=\"Value\" src=\"//images.uesp.net/thumb/5/52/SR-item-Gold-heads.png/22px-SR-item-Gold-heads.png\" width=\"22\" height=\"22\" srcset=\"//images.uesp.net/thumb/5/52/SR-item-Gold-heads.png/33px-SR-item-Gold-heads.png 1.5x, //images.uesp.net/thumb/5/52/SR-item-Gold-heads.png/44px-SR-item-Gold-heads.png 2x\" /></a>\n</th>\n<th><a href=\"/wiki/File:SR-icon-clothing-Leather_Backpack_(square).png\" class=\"image\" title=\"Weight\"><img alt=\"Weight\" src=\"//images.uesp.net/thumb/2/2d/SR-icon-clothing-Leather_Backpack_%28square%29.png/22px-SR-icon-clothing-Leather_Backpack_%28square%29.png\" width=\"22\" height=\"22\" srcset=\"//images.uesp.net/thumb/2/2d/SR-icon-clothing-Leather_Backpack_%28square%29.png/33px-SR-icon-clothing-Leather_Backpack_%28square%29.png 1.5x, //images.uesp.net/thumb/2/2d/SR-icon-clothing-Leather_Backpack_%28square%29.png/44px-SR-icon-clothing-Leather_Backpack_%28square%29.png 2x\" /></a>\n</th>\n<th><a href=\"/wiki/File:SR-item-Gold-heads.png\" class=\"image\" title=\"Value\"><img alt=\"Value\" src=\"//images.uesp.net/thumb/5/52/SR-item-Gold-heads.png/22px-SR-item-Gold-heads.png\" width=\"22\" height=\"22\" srcset=\"//images.uesp.net/thumb/5/52/SR-item-Gold-heads.png/33px-SR-item-Gold-heads.png 1.5x, //images.uesp.net/thumb/5/52/SR-item-Gold-heads.png/44px-SR-item-Gold-heads.png 2x\" /></a>\n</th></tr>\n<tr>\n<td><a href=\"/wiki/File:SR-icon-armor-Iron_Plate_Armor.png\" class=\"image\"><img alt=\"SR-icon-armor-Iron Plate Armor.png\" src=\"//images.uesp.net/thumb/b/b4/SR-icon-armor-Iron_Plate_Armor.png/48px-SR-icon-armor-Iron_Plate_Armor.png\" width=\"48\" height=\"48\" srcset=\"//images.uesp.net/thumb/b/b4/SR-icon-armor-Iron_Plate_Armor.png/72px-SR-icon-armor-Iron_Plate_Armor.png 1.5x, //images.uesp.net/thumb/b/b4/SR-icon-armor-Iron_Plate_Armor.png/96px-SR-icon-armor-Iron_Plate_Armor.png 2x\" /></a>\n</td>\n<td><span id=\"Iron_Plate_Armor\"></span>Iron Plate Armor<br /><span class=\"idall\">(<span class=\"idref\"><span class=\"idcase\">FE</span><a href=\"/wiki/Skyrim:Form_ID#Creation_Club\" title=\"Skyrim:Form ID\"><span style=\"cursor:help;\" title=\"These three digits vary depending on installed Creations. Click for more details.\">xxx</span></a><span class=\"idcase\">801</span></span>)</span></td>\n<td>31</td>\n<td>150</td>\n<td>27\n</td>\n<td style=\"border-left-width:medium; border-left-color:black;\">5</td>\n<td>3\n</td>\n<td style=\"border-left-width:medium; border-left-color:black; color:red\">25.7\n</td>\n<td>106\n</td>\n<td style=\"color:red\">5.85\n</td>\n<td>3.41\n</td></tr>\n<tr>\n<td style=\"text-align:center\"><a href=\"/wiki/File:SR-icon-armor-Iron_Plate_Boots.png\" class=\"image\"><img alt=\"SR-icon-armor-Iron Plate Boots.png\" src=\"//images.uesp.net/thumb/c/c0/SR-icon-armor-Iron_Plate_Boots.png/48px-SR-icon-armor-Iron_Plate_Boots.png\" width=\"48\" height=\"48\" srcset=\"//images.uesp.net/thumb/c/c0/SR-icon-armor-Iron_Plate_Boots.png/72px-SR-icon-armor-Iron_Plate_Boots.png 1.5x, //images.uesp.net/thumb/c/c0/SR-icon-armor-Iron_Plate_Boots.png/96px-SR-icon-armor-Iron_Plate_Boots.png 2x\" /></a>\n</td>\n<td><span id=\"Iron_Plate_Boots\"></span>Iron Plate Boots<br /><span class=\"idall\">(<span class=\"idref\"><span class=\"idcase\">FE</span><a href=\"/wiki/Skyrim:Form_ID#Creation_Club\" title=\"Skyrim:Form ID\"><span style=\"cursor:help;\" title=\"These three digits vary depending on installed Creations. Click for more details.\">xxx</span></a><span class=\"idcase\">800</span></span>)</span></td>\n<td>6</td>\n<td>35</td>\n<td>11\n</td>\n<td style=\"border-left-width:medium; border-left-color:black;\">3</td>\n<td>2\n</td>\n<td style=\"border-left-width:medium; border-left-color:black; color:red\">2.8\n</td>\n<td>8\n</td>\n<td style=\"color:red\">1.88\n</td>\n<td>1.3\n</td></tr>\n<tr>\n<td style=\"text-align:center\"><a href=\"/wiki/File:SR-icon-armor-Iron_Plate_Gauntlets.png\" class=\"image\"><img alt=\"SR-icon-armor-Iron Plate Gauntlets.png\" src=\"//images.uesp.net/thumb/a/ad/SR-icon-armor-Iron_Plate_Gauntlets.png/48px-SR-icon-armor-Iron_Plate_Gauntlets.png\" width=\"48\" height=\"48\" srcset=\"//images.uesp.net/thumb/a/ad/SR-icon-armor-Iron_Plate_Gauntlets.png/72px-SR-icon-armor-Iron_Plate_Gauntlets.png 1.5x, //images.uesp.net/thumb/a/ad/SR-icon-armor-Iron_Plate_Gauntlets.png/96px-SR-icon-armor-Iron_Plate_Gauntlets.png 2x\" /></a>\n</td>\n<td><span id=\"Iron_Plate_Gauntlets\"></span>Iron Plate Gauntlets<br /><span class=\"idall\">(<span class=\"idref\"><span class=\"idcase\">FE</span><a href=\"/wiki/Skyrim:Form_ID#Creation_Club\" title=\"Skyrim:Form ID\"><span style=\"cursor:help;\" title=\"These three digits vary depending on installed Creations. Click for more details.\">xxx</span></a><span class=\"idcase\">802</span></span>)</span></td>\n<td>5</td>\n<td>35</td>\n<td>11\n</td>\n<td style=\"border-left-width:medium; border-left-color:black;\">2</td>\n<td>2\n</td>\n<td style=\"border-left-width:medium; border-left-color:black; color:red\">2.8\n</td>\n<td>15\n</td>\n<td style=\"color:red\">2.27\n</td>\n<td>1.75\n</td></tr>\n<tr>\n<td style=\"text-align:center\"><a href=\"/wiki/File:SR-icon-armor-Iron_Plate_Helmet.png\" class=\"image\"><img alt=\"SR-icon-armor-Iron Plate Helmet.png\" src=\"//images.uesp.net/thumb/8/8d/SR-icon-armor-Iron_Plate_Helmet.png/48px-SR-icon-armor-Iron_Plate_Helmet.png\" width=\"48\" height=\"48\" srcset=\"//images.uesp.net/thumb/8/8d/SR-icon-armor-Iron_Plate_Helmet.png/72px-SR-icon-armor-Iron_Plate_Helmet.png 1.5x, //images.uesp.net/thumb/8/8d/SR-icon-armor-Iron_Plate_Helmet.png/96px-SR-icon-armor-Iron_Plate_Helmet.png 2x\" /></a>\n</td>\n<td><span id=\"Iron_Plate_Helmet\"></span>Iron Plate Helmet<br /><span class=\"idall\">(<span class=\"idref\"><span class=\"idcase\">FE</span><a href=\"/wiki/Skyrim:Form_ID#Creation_Club\" title=\"Skyrim:Form ID\"><span style=\"cursor:help;\" title=\"These three digits vary depending on installed Creations. Click for more details.\">xxx</span></a><span class=\"idcase\">803</span></span>)</span></td>\n<td>5</td>\n<td>75</td>\n<td>16\n</td>\n<td style=\"border-left-width:medium; border-left-color:black;\">3</td>\n<td>2\n</td>\n<td style=\"border-left-width:medium; border-left-color:black; color:red\">1.8\n</td>\n<td>48\n</td>\n<td style=\"color:red\">1.56\n</td>\n<td>2.78\n</td></tr>\n<tr class=\"sortbottom\">\n<td colspan=\"2\">Totals (with iron shield):\n</td>\n<td>59</td>\n<td>355</td>\n<td>85\n</td>\n<td style=\"border-left-width:medium; border-left-color:black;\">17</td>\n<td>10\n</td>\n<td style=\"border-left-width:medium; border-left-color:black;\" colspan=\"4\">\n</td></tr>\n\n<tr class=\"sortbottom\">\n<td colspan=\"2\">Totals:\n</td>\n<td>47</td>\n<td>295</td>\n<td>65\n</td>\n<td style=\"border-left-width:medium; border-left-color:black;\">13</td>\n<td>9\n</td>\n<td style=\"border-left-width:medium; border-left-color:black;\" colspan=\"4\">\n</td></tr>\n</tbody></table>\n<ul class=\"gallery mw-gallery-nolines\">\n\t\t<li class=\"gallerybox\" style=\"width: 205px\"><div style=\"width: 205px\">\n\t\t\t<div class=\"thumb\" style=\"width: 200px;\"><div style=\"margin:0px auto;\"><a href=\"/wiki/File:SR-item-Iron_Plate_Armor_Male.jpg\" class=\"image\"><img alt=\"\" src=\"//images.uesp.net/thumb/d/d4/SR-item-Iron_Plate_Armor_Male.jpg/200px-SR-item-Iron_Plate_Armor_Male.jpg\" width=\"200\" height=\"200\" srcset=\"//images.uesp.net/thumb/d/d4/SR-item-Iron_Plate_Armor_Male.jpg/300px-SR-item-Iron_Plate_Armor_Male.jpg 1.5x, //images.uesp.net/thumb/d/d4/SR-item-Iron_Plate_Armor_Male.jpg/400px-SR-item-Iron_Plate_Armor_Male.jpg 2x\" /></a></div></div>\n\t\t\t<div class=\"gallerytext\">\n<p>A male <a href=\"/wiki/Skyrim:Nord\" title=\"Skyrim:Nord\">Nord</a> wearing iron plate armor with a banded iron shield\n</p>\n\t\t\t</div>\n\t\t</div></li>\n</ul>\n\n<!-- \nNewPP limit repo