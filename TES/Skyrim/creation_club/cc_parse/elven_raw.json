_Hunter_Gauntlets.png/48px-SR-icon-armor-Elven_Hunter_Gauntlets.png\" width=\"48\" height=\"48\" srcset=\"//images.uesp.net/thumb/1/1c/SR-icon-armor-Elven_Hunter_Gauntlets.png/72px-SR-icon-armor-Elven_Hunter_Gauntlets.png 1.5x, //images.uesp.net/thumb/1/1c/SR-icon-armor-Elven_Hunter_Gauntlets.png/96px-SR-icon-armor-Elven_Hunter_Gauntlets.png 2x\" /></a>\n</td>\n<td><span id=\"Elven_Hunter_Gauntlets\"></span>Elven Hunter Gauntlets<br /><span class=\"idall\">(<span class=\"idref\"><span class=\"idcase\">FE</span><a href=\"/wiki/Skyrim:Form_ID#Creation_Club\" title=\"Skyrim:Form ID\"><span style=\"cursor:help;\" title=\"These three digits vary depending on installed Creations. Click for more details.\">xxx</span></a><span class=\"idcase\">802</span></span>)</span></td>\n<td>1</td>\n<td>45</td>\n<td>10\n</td>\n<td style=\"border-left-width:medium; border-left-color:black;\">1</td>\n<td>1</td>\n<td>1</td>\n<td>2\n</td>\n<td style=\"border-left-width:medium; border-left-color:black;\">-3.2\n</td>\n<td style=\"color:red\">-53\n</td>\n<td>0.24\n</td>\n<td style=\"color:red\">0.46\n</td></tr>\n\n<tr class=\"sortbottom\">\n<td colspan=\"2\">Totals:\n</td>\n<td>6</td>\n<td>315</td>\n<td>51\n</td>\n<td style=\"border-left-width:medium; border-left-color:black;\">7</td>\n<td>3</td>\n<td>3</td>\n<td>7\n</td>\n<td style=\"border-left-width:medium; border-left-color:black;\">-10.7\n</td>\n<td style=\"color:red\">-282\n</td>\n<td>0.36\n</td>\n<td style=\"color:red\">0.54\n</td></tr>\n<tr class=\"sortbottom\">\n<td colspan=\"2\">Totals (with regular helmet and shield):\n</td>\n<td>11</td>\n<td>540</td>\n<td>85\n</td>\n<td style=\"border-left-width:medium; border-left-color:black;\">9</td>\n<td>4</td>\n<td>4</td>\n<td>8\n</td>\n<td style=\"border-left-width:medium; border-left-color:black;\">-15.6\n</td>\n<td style=\"color:red\">-540\n</td>\n<td>0.41\n</td>\n<td style=\"color:red\">0.5\n</td></tr></tbody></table>\n<ul class=\"gallery mw-gallery-nolines\">\n\t\t<li class=\"gallerybox\"